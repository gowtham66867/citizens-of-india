# Citizens of India — backend environment variables
# Copy this to .env and fill in your values

# Required
GEMINI_API_KEY=your_google_ai_studio_key_here

# Required for multi-agent pipeline
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — protects /analytics/priorities, /agents/run, /analytics/export
# Leave empty to run open in development
MP_API_KEY=

# Optional — authenticates Cloud Scheduler webhook calls
CRON_SECRET=

# Storage — leave empty to use SQLite (auto fallback for local dev)
FIREBASE_CREDENTIALS_PATH=
GOOGLE_APPLICATION_CREDENTIALS=

# GCP project (needed for Firestore / BigQuery in production)
GCP_PROJECT_ID=your-gcp-project-id
